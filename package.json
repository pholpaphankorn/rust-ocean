{
  "name": "rust-ocean",
  "version": "1.0.0",
  "description": "Preview:",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "format": "prettier --write . && npm run format:engine",
    "format:check": "prettier --check . && npm run format:engine:check",
    "format:engine": "cargo fmt --manifest-path ./engine/Cargo.toml",
    "format:engine:check": "cargo fmt --manifest-path ./engine/Cargo.toml -- --check",
    "build:wasm": "wasm-pack build ./engine --target web --out-dir ../pkg",
    "build": "npm run build:wasm && vite build",
    "test:frontend": "vitest run",
    "test:engine": "cd engine && wasm-pack test --node"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pholpaphankorn/rust-ocean.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/pholpaphankorn/rust-ocean/issues"
  },
  "homepage": "https://github.com/pholpaphankorn/rust-ocean#readme",
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-wasm": "^3.6.0"
  }
}
